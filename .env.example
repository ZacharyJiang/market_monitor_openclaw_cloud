# ETF NEXUS 配置（腾讯云部署推荐）

# 行情刷新间隔（分钟）
REFRESH_MINUTES=2

# K线批量刷新间隔（分钟）
KLINE_REFRESH_MINUTES=180

# 每次批量更新的ETF数量
KLINE_BATCH_SIZE=2

# 每轮K线任务最多覆盖的ETF数（按成交额/规模优先）
KLINE_TOP_N=80

# 非交易时段是否强制刷新（调试用）
FORCE_REFRESH=false

# 网络请求超时（秒）
REQUEST_TIMEOUT_SECONDS=12

# 请求限频：基础间隔（秒）
API_BASE_INTERVAL=1.2

# 请求限频：最大间隔（秒）
API_MAX_INTERVAL=8.0

# 备用数据源（新浪/腾讯）请求最小间隔（秒）
SECONDARY_API_INTERVAL=0.45

# 熔断阈值：连续失败次数
CIRCUIT_BREAKER_THRESHOLD=4

# 熔断冷却时长（秒）
CIRCUIT_BREAKER_COOLDOWN=180

# 可选：统一代理（有跨境网络问题时再启用）
# MARKET_PROXY=http://user:pass@proxy-host:port

# 兼容旧变量名（可二选一）
# AKSHARE_PROXY=http://user:pass@proxy-host:port
